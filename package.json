{
  "name": "bibliotheque-front",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --no-progress",
    "test:watch": "ng test --watch=true",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "setup": "npm install && npm run docker:up",
    "docker:up": "docker-compose --env-file .env up -d",
    "docker:down": "docker-compose --env-file .env down",
    "docker:clean": "docker-compose --env-file .env down -v && npm run docker:up",
    "docker:rebuild": "docker-compose --env-file .env down -v && docker-compose --env-file .env build --no-cache && docker-compose --env-file .env up -d",
    "docker:restart": "docker-compose --env-file .env restart",
    "docker:logs": "docker-compose --env-file .env logs -f",
    "docker:ps": "docker-compose --env-file .env ps",
    "docker:build": "docker-compose --env-file .env build",
    "dev": "docker-compose -f docker-compose.dev.yml up -d && npm start",
    "dev:down": "docker-compose -f docker-compose.dev.yml down",
    "stop": "npm run docker:down",
    "audit": "npm audit --audit-level=moderate",
    "clean": "rm -rf dist coverage .angular",
    "docs": "compodoc -p tsconfig.doc.json -d docs-site -c compodoc.json"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@compodoc/compodoc": "^1.2.1",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "^5.1.0",
    "jasmine-core": "^5.1.1",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "^5.9.3"
  }
}
