# Configuration de l'application Bibliothèque
# Copier ce fichier en .env et adapter les valeurs

# ⚠️ IMPORTANT: Adapter le BACKEND_PATH à votre installation
# Format: Chemin absolu Windows avec slashes (PAS de backslashes!)
# Exemple: C:/Users/Emili/OneDrive/Bureau/CDA/JAVA/TP/bibliotheque
BACKEND_PATH=../bibliotheque-back-java

# Ports (modifier si vous avez des conflits)
FRONTEND_PORT=4200
BACKEND_PORT=8080
POSTGRES_PORT=5432
MAILPIT_PORT=8025

# Configuration PostgreSQL (adapter si besoin)
POSTGRES_DB=bibliotheque
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Profil Spring (docker, test, dev, prod)
SPRING_PROFILES_ACTIVE=docker
